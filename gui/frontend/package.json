{
	"name": "ani-gui-frontend",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=20.11"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && pnpm i18n:compile && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && pnpm i18n:compile && svelte-check --tsconfig ./tsconfig.json --watch",
		"i18n:compile": "node tools/build-messages.mjs && paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"test": "pnpm i18n:compile && vitest run",
		"test:watch": "vitest",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"prepare": "lefthook install -f"
	},
	"dependencies": {
		"hls.js": "1.6.16",
		"lottie-web": "5.13.0"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@inlang/paraglide-js": "^2.18.0",
		"@sveltejs/adapter-static": "3.0.10",
		"@sveltejs/kit": "2.59.1",
		"@sveltejs/vite-plugin-svelte": "7.1.1",
		"@types/node": "25.6.0",
		"@vitest/coverage-v8": "^4.1.5",
		"eslint": "10.3.0",
		"eslint-plugin-svelte": "3.17.1",
		"fast-check": "^4.7.0",
		"globals": "17.6.0",
		"happy-dom": "^20.9.0",
		"lefthook": "2.1.6",
		"prettier": "3.8.3",
		"prettier-plugin-svelte": "3.5.1",
		"svelte": "5.55.5",
		"svelte-check": "4.4.8",
		"typescript": "6.0.3",
		"typescript-eslint": "8.59.2",
		"vite": "8.0.10",
		"vitest": "4.1.5"
	}
}
