node_modules/
.svelte-kit/
build/
dist/
.env
.env.*
!.env.example
.vite/

# Paraglide compiles `messages/<locale>.json` → typed TS in
# `src/lib/paraglide/`. Generated; regenerated on dev / build /
# test / CI via the `i18n:compile` script (also chained into
# `check` and `test`).
src/lib/paraglide/

# Paraglide / inlang local cache + meta — regenerated on every
# compile, no value in committing.
project.inlang/cache/
project.inlang/.meta.json

# Per-locale merged bundles. Source of truth lives in
# `messages/<locale>/<namespace>.json`; `tools/build-messages.mjs`
# stitches those into the single `messages/<locale>.json` file
# Paraglide reads. Regenerated on every i18n:compile.
messages/*.json
