{
	"name": "ani-gui",
	"version": "0.1.1",
	"description": "Electron shell for ani-gui — spawns the Rust backend as a sidecar and renders the SvelteKit frontend",
	"homepage": "https://github.com/pucci/ani-gui",
	"author": {
		"name": "ani-gui contributors",
		"email": "dev@thirdmovement.net"
	},
	"private": true,
	"main": "main.js",
	"scripts": {
		"dev": "ELECTRON_DEV=1 electron --no-sandbox .",
		"start": "electron .",
		"build:backend": "cd ../backend && cargo build --bin ani-gui-backend --release",
		"build:frontend": "cd ../frontend && pnpm build",
		"fetch:win-deps": "node scripts/fetch-windows-deps.mjs",
		"fetch:linux-deps": "node scripts/fetch-linux-deps.mjs",
		"package": "pnpm run build:backend && pnpm run build:frontend && pnpm run dist",
		"package:release": "pnpm run build:backend && pnpm run build:frontend && pnpm run dist:release",
		"package:win": "pnpm run fetch:win-deps && pnpm run build:backend && pnpm run build:frontend && pnpm run dist:win",
		"dist": "pnpm run fetch:linux-deps && electron-builder --linux AppImage && pnpm run repack-appimage",
		"dist:release": "pnpm run fetch:linux-deps && electron-builder --linux AppImage deb && pnpm run repack-appimage",
		"dist:win": "electron-builder --win nsis",
		"repack-appimage": "node scripts/repack-appimage.mjs",
		"e2e": "pnpm run package && playwright test",
		"e2e:fast": "playwright test"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"electron": "^33.2.0",
		"electron-builder": "^25.1.8"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"electron"
		]
	},
	"build": {
		"appId": "net.thirdmovement.ani-gui",
		"productName": "ani-gui",
		"directories": {
			"output": "dist",
			"buildResources": "build-resources"
		},
		"files": [
			"main.js",
			"preload.js",
			"package.json",
			"node_modules/**/*"
		],
		"extraResources": [
			{
				"from": "../frontend/build",
				"to": "frontend/build"
			},
			{
				"from": "../backend/target/release/ani-gui-backend",
				"to": "ani-gui-backend"
			},
			{
				"from": "../../ani-cli",
				"to": "ani-cli"
			}
		],
		"linux": {
			"target": [
				"AppImage",
				"deb"
			],
			"category": "AudioVideo",
			"executableName": "ani-gui",
			"artifactName": "${productName}-${version}-${arch}.${ext}",
			"maintainer": "ani-gui contributors <dev@thirdmovement.net>",
			"extraResources": [
				{
					"from": "build-resources/linux/bin",
					"to": "bin"
				}
			]
		},
		"deb": {
			"afterInstall": "build-resources/deb-after-install.sh",
			"afterRemove": "build-resources/deb-after-remove.sh",
			"depends": [
				"curl",
				"sed",
				"grep",
				"coreutils"
			],
			"recommends": [
				"ffmpeg"
			]
		},
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				}
			],
			"artifactName": "${productName}-${version}-${arch}-setup.${ext}",
			"extraResources": [
				{
					"from": "../frontend/build",
					"to": "frontend/build"
				},
				{
					"from": "../backend/target/release/ani-gui-backend.exe",
					"to": "ani-gui-backend.exe"
				},
				{
					"from": "../../ani-cli",
					"to": "ani-cli"
				},
				{
					"from": "build-resources/win/bin",
					"to": "bin"
				}
			]
		},
		"nsis": {
			"oneClick": false,
			"perMachine": false,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true,
			"shortcutName": "ani-gui",
			"include": "build-resources/installer.nsh"
		}
	}
}
