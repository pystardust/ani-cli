{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ani-gui",
  "version": "0.1.0",
  "identifier": "net.thirdmovement.ani-gui",
  "build": {
    "beforeDevCommand": "pnpm --dir ../frontend dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --dir ../frontend build",
    "frontendDist": "../frontend/build"
  },
  "app": {
    "windows": [
      {
        "title": "ani-gui",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; media-src http://127.0.0.1:* image://*; img-src 'self' data: image://* https://media.kitsu.app https://s4.anilist.co; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:* https://kitsu.io https://graphql.anilist.co"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "dmg", "msi"],
    "category": "Video",
    "shortDescription": "Desktop GUI for ani-cli",
    "longDescription": "Browse and watch anime through a graphical interface backed by the ani-cli scraper.",
    "resources": ["../../ani-cli"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["curl", "openssl", "fzf", "mpv", "ffmpeg", "aria2"]
      }
    }
  }
}
